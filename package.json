{
  "name": "html-dailyupdate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Home-lab daily HTML briefing for AI, AI governance, AI vendors, data centers, and related tech news.",
  "scripts": {
    "generate": "node src/jobs/daily.mjs --sample",
    "dry-run": "node src/jobs/daily.mjs --dry-run",
    "daily": "node src/jobs/daily.mjs",
    "send": "node src/jobs/daily.mjs --send",
    "eais:init-db": "node --no-warnings=ExperimentalWarning src/jobs/eais-db.mjs init",
    "eais:import-digest": "node --no-warnings=ExperimentalWarning src/jobs/eais-db.mjs import-digest",
    "eais:summary": "node --no-warnings=ExperimentalWarning src/jobs/eais-db.mjs summary",
    "eais:serve": "node --no-warnings=ExperimentalWarning src/server/eais-server.mjs",
    "eais:install-daily-timer": "bash scripts/install-eais-daily-timer.sh",
    "test": "node --no-warnings=ExperimentalWarning tests/render-smoke.mjs && node --no-warnings=ExperimentalWarning tests/eais-db-smoke.mjs && node --no-warnings=ExperimentalWarning tests/eais-server-smoke.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "nodemailer": "^8.0.8"
  }
}
