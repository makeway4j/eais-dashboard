# Daily schedule
DIGEST_TIME_LOCAL=06:00
TIMEZONE=America/Chicago
DIGEST_MODE=live
MAX_ITEMS_PER_SOURCE=5
MAX_TOTAL_ITEMS=24

# EAIS production database
EAIS_DB_PATH=data/eais.db
LEGACY_DIGEST_DB_PATH=/opt/digest/digest.db

# Safety: dry-run writes HTML/logs but does not send. Use send after Gmail SMTP is tested.
EMAIL_SEND_MODE=dry-run

# Daily brief archive: off, local, api, or server.
# Use local first on CT 301. `api` is the Joplin Desktop/Web Clipper API.
# `server` is the always-on Joplin Server sync API on CT 111.
JOPLIN_SAVE_MODE=off
JOPLIN_LOCAL_EXPORT_DIR=archives/joplin
JOPLIN_API_BASE=http://127.0.0.1:41184
JOPLIN_SERVER_BASE=http://127.0.0.1:22300
JOPLIN_TOKEN=
JOPLIN_SERVER_TOKEN=
JOPLIN_SERVER_EMAIL=
JOPLIN_SERVER_PASSWORD=
JOPLIN_NOTEBOOK_ID=
JOPLIN_NOTEBOOK_TITLE=EAIS

# OpenAI API
# ChatGPT subscriptions and API billing are separate. Use an API key here when live AI summarization is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ENABLE_OPENAI_SUMMARY=false

# Email provider choice: gmail_smtp, brevo_smtp, resend_api, sendgrid_api
EMAIL_PROVIDER=gmail_smtp
EMAIL_FROM="AI Daily <your-address@example.com>"
EMAIL_TO="you@example.com"

# SMTP options for Gmail, Google Workspace, Brevo, or another SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# API provider options, used only if EMAIL_PROVIDER is resend_api or sendgrid_api
RESEND_API_KEY=
SENDGRID_API_KEY=

# Future modules
ENABLE_SOCIAL_DRAFTS=false
ENABLE_JOB_RECOMMENDATIONS=false
